# Copy this file to .env in the same folder on the Linux server.

DB_NAME=mgps_master
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_PORT=5432

# Path to the code repository on the Linux server.
CODE_DIR=/home/mgps01/mgpsv2/code/mgpsfren/mgps-fenchise-app

BACKEND_PORT=8080
FRONTEND_PORT=80

# Frontend must call the backend URL accessible from the browser.
# When using the Nginx reverse proxy, keep this as /api so the browser calls
# the same host and the proxy forwards it to the backend container.
VITE_API_BASE_URL=/api

# Spring Boot / JWT settings
JWT_SECRET=change-this-to-a-long-random-value
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://YOUR_SERVER_IP,http://YOUR_SERVER_IP:80
